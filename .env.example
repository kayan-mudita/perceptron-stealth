# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/official_ai?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# AI Video Generation
KLING_API_KEY=""
SEEDANCE_API_KEY=""

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_AUTHORITY="price_..."
STRIPE_PRICE_EXPERT="price_..."

# ──────────────────────────────────────────────────────────────
# S3-compatible File Storage
# Works with AWS S3, Cloudflare R2, MinIO, or any S3-compatible service.
# Leave S3_BUCKET blank to disable file uploads (photos/voices/videos).
# ──────────────────────────────────────────────────────────────

# Required
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Optional – defaults shown
S3_REGION="us-east-1"

# Set this for non-AWS providers (Cloudflare R2, MinIO, etc.)
# e.g. "https://<account-id>.r2.cloudflarestorage.com"
# e.g. "http://localhost:9000" for local MinIO
S3_ENDPOINT=""

# Set to a public CDN or bucket URL to serve files directly instead of
# generating presigned URLs (e.g. "https://cdn.example.com/uploads")
S3_PUBLIC_URL=""

# Set to "true" for providers that require path-style access (e.g. MinIO)
S3_FORCE_PATH_STYLE=""
