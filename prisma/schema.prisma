generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  industry       String   @default("other")
  company        String?
  avatarUrl      String?
  plan                    String    @default("free")
  stripeCustomerId        String?   @unique
  stripePriceId           String?
  stripeSubscriptionId    String?
  stripeCurrentPeriodEnd  DateTime?
  emailVerified           Boolean   @default(false)
  signupRef      String?
  onboarded      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  photos                  Photo[]
  voiceSamples            VoiceSample[]
  videos                  Video[]
  schedules               Schedule[]
  socialAccounts          SocialAccount[]
  brandProfile            BrandProfile?
  brandKit                BrandKit?
  analytics               AnalyticsEvent[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  characterSheets         CharacterSheet[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BrandProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  brandName      String?
  tagline        String?
  toneOfVoice    String?
  targetAudience String?
  competitors    String?
  brandColors    String?
  guidelines     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Photo {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  filename      String
  url           String
  isPrimary     Boolean  @default(false)
  photoAnalysis String?  // JSON: PhotoAnalysis from photo-analyzer.ts
  createdAt     DateTime @default(now())

  videos Video[]
}

model VoiceSample {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  url             String
  duration        Int      @default(0)
  isDefault       Boolean  @default(false)
  provider        String?  // "elevenlabs" | "minimax" | "fal"
  providerVoiceId String?  // Voice ID from the cloning provider
  createdAt       DateTime @default(now())

  videos Video[]
}

model Video {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  title         String
  description   String?
  script        String?
  status        String   @default("draft")
  model         String   @default("kling_2.6")
  videoUrl      String?
  thumbnailUrl  String?
  duration      Int      @default(0)
  contentType   String   @default("general")
  sourceReview  String?
  photoId       String?
  photo         Photo?   @relation(fields: [photoId], references: [id])
  voiceId       String?
  voice         VoiceSample? @relation(fields: [voiceId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schedule        Schedule?
  analyticsEvents AnalyticsEvent[]
}

model Schedule {
  id          String   @id @default(uuid())
  videoId     String   @unique
  video       Video    @relation(fields: [videoId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  platform    String
  scheduledAt DateTime
  publishedAt DateTime?
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())
}

model SocialAccount {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  platform     String
  handle       String
  connected    Boolean   @default(true)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  accountId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, platform])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String?
  video     Video?   @relation(fields: [videoId], references: [id])
  eventType String
  platform  String?
  count     Int      @default(1)
  date      DateTime @default(now())
}

// ─── Character Sheets ───────────────────────────────────────────

model CharacterSheet {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String   // "poses" | "3d_360"
  compositeUrl String?
  status        String   @default("generating") // generating | complete | failed
  selectedPose  Int?     // 0-8 index of user's preferred pose from 3x3 grid
  createdAt     DateTime @default(now())

  images CharacterSheetImage[]
}

model CharacterSheetImage {
  id               String         @id @default(uuid())
  characterSheetId String
  characterSheet   CharacterSheet @relation(fields: [characterSheetId], references: [id], onDelete: Cascade)
  url              String
  position         Int
  angle            String?
  createdAt        DateTime       @default(now())
}

// ─── Brand Kit ──────────────────────────────────────────────────

model BrandKit {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  logoUrl        String?
  primaryColor   String   @default("#4c6ef5")
  secondaryColor String   @default("#7c3aed")
  introStyle     String   @default("professional") // professional | casual | bold
  outroTemplate  String   @default("standard")     // standard | minimal | animated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Lifecycle Events (PLG tracking) ─────────────────────────────

model LifecycleEvent {
  id        String   @id @default(uuid())
  userId    String
  event     String   // signup, first_photo, first_video, first_publish, day_7, day_30
  metadata  String?  // JSON string for extra context
  createdAt DateTime @default(now())

  @@index([userId, event])
  @@index([event, createdAt])
}

// ─── Research Sessions (post-payment strategy generation) ───────

model ResearchSession {
  id               String    @id @default(uuid())
  userId           String
  industry         String
  companyName      String?
  websiteUrl       String?
  businessStatus   String    @default("queued")   // queued | processing | complete | failed
  businessResult   String?   // JSON: services, positioning, tone, audience, geography
  trendsStatus     String    @default("queued")
  trendsResult     String?   // JSON: trending topics, evergreen, seasonal, platform angles
  competitorStatus String    @default("queued")
  competitorResult String?   // JSON: competitors, gaps, opportunities
  calendarStatus   String    @default("queued")
  calendarResult   String?   // JSON: 30-day calendar with topics, hooks, scripts
  approvedDays     String?   // JSON: array of approved day indices e.g. [0,1,2,5,8]
  status           String    @default("processing") // processing | complete | failed
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([userId, createdAt])
}

// ─── System Configuration ───────────────────────────────────────

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  label     String
  category  String   // "models" | "prompts" | "onboarding"
  updatedAt DateTime @updatedAt
}
